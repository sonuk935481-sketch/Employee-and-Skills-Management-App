@page "/employees/edit/{id:int}"
@using Employee_and_Skills_Management_App.Model
@using Employee_and_Skills_Management_App.Services
@using Microsoft.AspNetCore.Components.Forms
@inject Employee_and_Skills_Management_App.Services.IEmployeeService EmployeeService
@inject NavigationManager NavigationManager

<PageTitle>Edit Employee</PageTitle>

<h3>Edit Employee</h3>



@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="employee" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit" FormName="editEmployee">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="mb-3">
            <label>First Name</label>
            <input id="firstName" class="form-control" type="text" value="@employee?.FirstName" @oninput="@( (ChangeEventArgs e) => employee.FirstName = e.Value?.ToString() )" />
            <ValidationMessage For="() => employee.FirstName" />
        </div>

        <div class="mb-3">
            <label>Last Name</label>
            <input id="lastName" class="form-control" type="text" value="@employee?.LastName" @oninput="@( (ChangeEventArgs e) => employee.LastName = e.Value?.ToString() )" />
            <ValidationMessage For="() => employee.LastName" />
        </div>

        <div class="mb-3">
            <label>Date Of Birth</label>
            <InputDate id="dob" class="form-control" @bind-Value="employee.DateOfBirth" TValue="System.DateTime" />
            <ValidationMessage For="() => employee.DateOfBirth" />
        </div>

        <div class="mb-3">
            <label>Phone</label>
            <input id="phone" class="form-control" type="text" value="@employee?.Phone" @oninput="@( (ChangeEventArgs e) => employee.Phone = e.Value?.ToString() )" />
           
            <ValidationMessage For="() => employee.Phone" />
        </div>

        <div class="mb-3">
            <label>Skills</label>
            <div>
                @if (skills == null)
                {
                    <div>Loading skills...</div>
                }
                else
                {
                    @foreach (var s in skills)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="skill_@s.Id" @onchange="e => ToggleSkill(e, s.Id)" checked="@selectedSkillIds.Contains(s.Id)" />
                            <label class="form-check-label" for="skill_@s.Id">@s.Name</label>
                        </div>
                    }
                }
            </div>
        </div>

        <button class="btn btn-primary" type="submit" disabled="@isSaving">Save</button>
        <a class="btn btn-secondary ms-2" href="/employees">Back</a>
    </EditForm>
}

@code {
    [Parameter]
    public int id { get; set; }

    private Employee employee = new Employee();
    private List<Skills> skills;
    private HashSet<int> selectedSkillIds = new();
    private string errorMessage;
    private bool isSaving = false;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            skills = await EmployeeService.GetAllSkillsAsync();
            var e = await EmployeeService.GetEmployeeAsync(id);
            if (e != null)
            {
                employee = e;
                selectedSkillIds = employee.Skills?.Select(s => s.Id).ToHashSet() ?? new();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleSkill(ChangeEventArgs e, int skillId)
    {
        var isChecked = e.Value is bool b && b;
        if (isChecked)
            selectedSkillIds.Add(skillId);
        else
            selectedSkillIds.Remove(skillId);
    }

    private void HandleInvalidSubmit(EditContext ctx)
    {
        errorMessage = "Please fix validation errors.";
    }

    private async Task HandleValidSubmit()
    {
        if (employee == null) return;

        isSaving = true;
        errorMessage = null;
        try
        {
            var skillIds = selectedSkillIds.Any() ? selectedSkillIds.ToArray() : Array.Empty<int>();
            await EmployeeService.UpdateEmployeeAsync(employee, skillIds);
            NavigationManager.NavigateTo("/employees");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }
}
