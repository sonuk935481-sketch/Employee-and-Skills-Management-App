@page "/employees"
@using Employee_and_Skills_Management_App.Model
@using Microsoft.EntityFrameworkCore
@inject Employee_and_Skills_Management_App.Data.ApplicationDbContext Db

<PageTitle>Employees</PageTitle>

<h3>Employees</h3>

<a class="btn btn-primary mb-3" href="/employees/create">Add Employee</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>First name</th>
            <th>Last name</th>
            <th>Date of birth</th>
            <th>Phone</th>
            <th>Skills</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (employees is null)
        {
            <tr><td colspan="4">Loading...</td></tr>
        }
        else if (!employees.Any())
        {
            <tr><td colspan="4">No employees found.</td></tr>
        }
        else
        {
            foreach (var e in employees)
            {
                <tr>
                    <td>@e.FirstName</td>
                    <td>@e.LastName</td>
                    <td>@e.DateOfBirth.ToShortDateString()</td>
                    <td>@e.Phone</td>
                    <td>@(e.Skills != null && e.Skills.Any() ? string.Join(", ", e.Skills.Select(s => s.Name)) : "-")</td>
                    <td>
                        <a class="btn btn-sm btn-secondary me-1" href="/employees/edit/@e.Id" onclick="invokeEdit(event, @e.Id)">Edit</a>
                        <a class="btn btn-sm btn-danger" href="/employees/delete/@e.Id">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private List<Employee> employees;

    protected override async Task OnInitializedAsync()
    {
        employees = await Db.Employees.Include(e => e.Skills).ToListAsync();
    }
}

<script>
    function invokeEdit(e, id) {
        // prevent default link navigation so we can ensure client-side load
        e.preventDefault();
        // navigate to edit route then call load function after small delay to allow DOM render
        window.location.href = '/employees/edit/' + id;
        // call load after navigation anchor; the edit page script will load on render and can be triggered by that navigation
    }
</script>
